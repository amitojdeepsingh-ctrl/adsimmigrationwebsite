ll,{"dangerouslySetInnerHTML":{"__html":"No employer sponsorship required"}}]]}]]}],["$","p","35",{"className":"text-gray-700 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong>Duration:</strong> The SOWP typically matches the duration of your permit. If you're on a 2-year study permit, your spouse gets a 2-year SOWP."}}],["$","h2","37",{"className":"text-2xl font-bold text-gray-900 mt-10 mb-4","children":"The Dual Application Strategy"}],["$","p","39",{"className":"text-gray-700 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"One of the most effective family immigration strategies we recommend:"}}],["$","p","41",{"className":"text-gray-700 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"1. <strong>Primary applicant</strong> gets a study permit or work permit"}}],["$","p","42",{"className":"text-gray-700 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"2. <strong>Spouse</strong> applies for SOWP simultaneously"}}],["$","p","43",{"className":"text-gray-700 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"3. Both arrive in Canada together"}}],["$","p","44",{"className":"text-gray-700 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"4. Primary applicant studies/works; spouse works full-time"}}],["$","p","45",{"className":"text-gray-700 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"5. Both accumulate Canadian income and experience"}}],["$","p","46",{"className":"text-gray-700 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"6. Both contribute to household finances while building PR eligibility"}}],["$","p","48",{"className":"text-gray-700 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"This strategy turns immigration from a costly process into an income-generating one — while simultaneously building both spouses' Canadian experience for future PR applications."}}],["$","h2","50",{"className":"text-2xl font-bold text-gray-900 mt-10 mb-4","children":"SOWP + Study Permit: 